{
  "scopeName": "source.delta",
  "patterns": [
    {
      "name": "comment.line.double-slash.delta",
      "match": "//.*$"
    },
    {
      "name": "comment.block.delta",
      "begin": "/\\*",
      "end": "\\*/"
    },
    {
      "name": "string.quoted.double.delta",
      "begin": "\"",
      "end": "\""
    },
    {
      "name": "constant.numeric.delta",
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
    },
    {
      "name": "keyword.control.delta",
      "match": "\\b(if|else|when|event|logicstream)\\b"
    },
    {
      "name": "variable.other.delta",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  ]
}